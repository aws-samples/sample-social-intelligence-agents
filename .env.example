# Required -- AgentCore Runtime ARN from CDK output (RuntimeArn)
AGENTCORE_AGENT_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789012:runtime/social_intel-XXXXXXXXXX

# AWS region where the stack is deployed
AWS_DEFAULT_REGION=us-east-1

# AWS CLI profile (optional -- falls back to default credentials)
# AWS_PROFILE=default

# DynamoDB table name (default: social-intel-leads, matches CDK stack)
# LEADS_TABLE_NAME=social-intel-leads

# Runtime application log group from CDK output; used by scripts/benchmark.py
# AGENTCORE_EVENT_LOG_GROUP=/aws/bedrock-agentcore/social-intelligence/application

# Email qualification policy (defaults shown)
# EMAIL_SCORE_THRESHOLD=60
# MIN_INDEPENDENT_SOURCES=2
